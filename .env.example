# ScanVault environment variables
# Copy this file to .env and fill in the values.
# docker-compose already sets sensible defaults; .env is for local `go run` usage.

# ── Required ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://scanvault:scanvault@localhost:5432/scanvault?sslmode=disable

# ── HTTP Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# ── Logging ─────────────────────────────────────────────────────────────────────
# Accepted values: debug | info | warn | error
LOG_LEVEL=info
# Accepted values: json (structured, for log aggregators) | console (human-readable)
LOG_FORMAT=json

# ── pgx Connection Pool Tuning (all optional - defaults shown) ──────────────────
# Maximum number of connections in the pool
DB_MAX_CONNS=25

# Minimum number of idle connections to keep open
DB_MIN_CONNS=2

# Maximum time a connection may be reused (Go duration string, e.g. 30m, 1h)
DB_MAX_CONN_LIFETIME=30m

# Maximum time a connection may sit idle before being closed
DB_MAX_CONN_IDLE_TIME=5m

# How often the pool pings idle connections for liveness
DB_HEALTH_CHECK_PERIOD=1m

# ── Cleanup Worker (all optional - disabled by default) ────────────────────────
# How often the cleanup worker runs (Go duration string, e.g. 30m, 1h, 24h)
CLEANUP_INTERVAL=1h

# Age-based: delete scans older than this duration. 0 = disabled.
# Examples: 72h (3 days), 168h (1 week), 720h (30 days)
CLEANUP_MAX_AGE=0

# Count-based: keep only the N most recent scans per image name. 0 = disabled.
# Example: CLEANUP_KEEP_PER_IMAGE=10
CLEANUP_KEEP_PER_IMAGE=0
